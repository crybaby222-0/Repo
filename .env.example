# Servidor
PORT=3333
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173,https://seu-dashboard.lovable.app

# Banco de dados PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/kira?schema=public"

# JWT (gere com: openssl rand -base64 64)
JWT_SECRET=troque-por-uma-chave-bem-longa-e-aleatoria
JWT_EXPIRES_IN=7d

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_BUSINESS=price_...

# URL do frontend (para redirect pós-checkout e reset de senha)
FRONTEND_URL=http://localhost:5173

# E-mail (recuperação de senha) — opcional em dev
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Kira Bot <no-reply@kirabot.com>"

# Diretório onde Baileys salva sessões
BAILEYS_AUTH_DIR=./baileys-auth
